# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline

# ─── Core API ────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pipeline
SPRING_DATASOURCE_USERNAME=pipeline
SPRING_DATASOURCE_PASSWORD=pipeline

# Dispatch mode: "http" (POST to worker) or "noop" (skip dispatch)
APP_QUEUE_DISPATCH_MODE=http
APP_WORKER_URL=http://worker:8000/internal/tasks/analyze
APP_CALLBACK_URL=http://core-api:8082/internal/jobs/callbacks

# Internal API shared secret (simple auth between services)
APP_INTERNAL_SHARED_SECRET=local-dev-secret

# ─── Worker ──────────────────────────────────────────────────
# Analysis provider: "mock" (fixture data) or "local" (heuristic analysis)
ANALYSIS_PROVIDER=local

CORE_CLAIM_URL=http://core-api:8082/internal/jobs/claim
CORE_CLAIM_STUB_MODE=false
CALLBACK_STUB_MODE=false
CALLBACK_TIMEOUT_SECONDS=5.0

STORAGE_BACKEND=filesystem
STORAGE_BASE_DIR=/data/artifacts

INTERNAL_SHARED_SECRET=local-dev-secret
